  "shortcuts": [
    {
      "name": "Add Meal",
      "short_name": "Add Meal",
      "description": "Quickly add a meal to your plan",
      "url": "/dashboard/meal-plan?action=add",
      "icons": [{ "src": "/icons/shortcut-add-meal.png", "sizes": "96x96" }]
    },
    {
      "name": "Recipes",
      "short_name": "Recipes",
      "description": "Browse your recipe collection",
      "url": "/dashboard/recipes",
      "icons": [{ "src": "/icons/shortcut-recipes.png", "sizes": "96x96" }]
    },
    {
      "name": "Shopping List",
      "short_name": "Shopping",
      "description": "View your shopping list",
      "url": "/dashboard/shopping-list",
      "icons": [{ "src": "/icons/shortcut-shopping.png", "sizes": "96x96" }]
    }
  ],
  "share_target": {
    "action": "/dashboard/recipes/import",
    "method": "POST",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+mealplanner",
      "url": "/dashboard/recipes/import?url=%s"
    }
  ]
