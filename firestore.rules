rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to check ownership
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Profiles can only be read and updated by the owner.
    match /profiles/{userId} {
      allow read, update: if isOwner(userId);
    }
    
    // Recipes can be read by anyone if they are public (user_id is null).
    // Users can read their own recipes.
    // Users can only create/update/delete their own recipes.
    match /recipes/{recipeId} {
      allow read: if resource.data.user_id == null || (request.auth != null && resource.data.user_id == request.auth.uid);
      allow create: if isOwner(request.resource.data.user_id);
      allow update, delete: if isOwner(resource.data.user_id);
    }
    
    // Users can only manage their own data in these collections.
    match /planned_meals/{mealId} {
      allow read, create, update, delete: if isOwner(request.resource.data.user_id);
    }
    
    match /pantry_items/{itemId} {
       allow read, create, update, delete: if isOwner(request.resource.data.user_id);
    }
    
    match /daily_weight_logs/{logId} {
      allow read, create, update, delete: if isOwner(request.resource.data.user_id);
    }
    
    match /daily_vitals_logs/{logId} {
       allow read, create, update, delete: if isOwner(request.resource.data.user_id);
    }

    match /daily_manual_macros_logs/{logId} {
       allow read, create, update, delete: if isOwner(request.resource.data.user_id);
    }
    
    // Default deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}