rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the requesting user is the owner of the document.
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // --- User Profile ---
    // Users can only read and write to their own profile document.
    match /profiles/{userId} {
      allow read, write: if isOwner(userId);
    }

    // --- Recipes ---
    // Recipes have special rules:
    // - ANY authenticated user can READ any recipe (both built-in and custom ones from other users).
    // - Users can only CREATE recipes for themselves.
    // - Users can only UPDATE or DELETE recipes they own.
    match /recipes/{recipeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && isOwner(request.resource.data.user_id);
      allow update, delete: if isOwner(resource.data.user_id);
    }

    // --- User-Specific Collections (Meals, Pantry, Logs) ---
    // For these collections, users can only read or write documents they own.
    match /planned_meals/{mealId} {
      allow read, write: if isOwner(resource.data.user_id);
    }

    match /pantry_items/{itemId} {
      allow read, write: if isOwner(resource.data.user_id);
    }

    match /daily_weight_logs/{logId} {
      allow read, write: if isOwner(resource.data.user_id);
    }
    
    match /daily_vitals_logs/{logId} {
        allow read, write: if isOwner(resource.data.user_id);
    }

    match /daily_manual_macros_logs/{logId} {
        allow read, write: if isOwner(resource.data.user_id);
    }
    
    match /bug_reports/{reportId} {
      allow create: if request.auth != null; // Allow any authenticated user to create a bug report.
      allow read, write, delete: if false; // Disallow any client-side reading/updating/deleting of reports.
    }
  }
}